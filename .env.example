SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-socket-mode-app-token
SLACK_SIGNING_SECRET=

# Comma, semicolon, or newline separated repo bindings.
# Use WSL/Linux paths when running from WSL.
CODEX_ALLOWED_REPOS=default=/absolute/path/to/your/repo
CODEX_DEFAULT_REPO_ID=default
CODEX_WORKTREE_ROOT=.codex-slack/worktrees
CODEX_STORE_KIND=json
CODEX_STATE_PATH=.codex-slack/state.json
CODEX_DATABASE_PATH=.codex-slack/state.db
CODEX_COMMAND=codex
CODEX_MODEL=
CODEX_RUNNER_ENV_ALLOWLIST=PATH,HOME,USER,USERNAME,SHELL,TMPDIR,TMP,TEMP,LANG,LC_ALL,TERM,NO_COLOR,CODEX_HOME
CODEX_PROFILES_PATH=infra/codex/profiles.toml
CODEX_RULES_PATH=infra/codex/default.rules
CODEX_REQUIRE_EXECPOLICY_CHECK=true
# Optional source-working-tree quick mode. Disabled by default.
CODEX_DIRECT_WORKSPACE_ENABLED=false
CODEX_DIRECT_WORKSPACE_ALLOWED_REPOS=
CODEX_DIRECT_WORKSPACE_REQUIRE_CLEAN=true
AUDIT_VIEWER_HOST=127.0.0.1
AUDIT_VIEWER_PORT=1787
# Keep false for localhost-only local use. Remote binds require true plus AUDIT_VIEWER_PASSWORD.
AUDIT_VIEWER_ALLOW_REMOTE=false
AUDIT_VIEWER_REQUIRE_AUTH=false
AUDIT_VIEWER_USERNAME=codex-relay
AUDIT_VIEWER_PASSWORD=

# Security policy.
# strict is fail-closed and requires repo-specific user/channel policy for repo actions.
# local-dev permits empty allowlists and should only be used on isolated development machines.
CODEX_POLICY_MODE=strict
CODEX_ALLOWED_SLACK_USERS=U1234567890
CODEX_MAINTAINER_SLACK_USERS=
CODEX_ALLOWED_SLACK_CHANNELS=C1234567890
# Repo-specific policy entries use repo=id1|id2; separate repos with commas, semicolons, or newlines.
CODEX_REPO_ALLOWED_SLACK_USERS=default=U1234567890
CODEX_REPO_ALLOWED_SLACK_CHANNELS=default=C1234567890

# Optional generic email control plane foundation. Disabled by default.
# Use with a local mailbox bridge or polling daemon only after reviewing docs/SECURITY.md.
EMAIL_CONTROL_PLANE_ENABLED=false
EMAIL_ALLOWED_SENDERS=
EMAIL_MAILBOX_ID=default
EMAIL_DEFAULT_REPO_ID=
EMAIL_DIRECT_WORKSPACE_ENABLED=false
EMAIL_IMAP_ENABLED=false
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_TLS_REJECT_UNAUTHORIZED=true
EMAIL_IMAP_USER=
EMAIL_IMAP_PASSWORD=
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_IMAP_POLL_MS=10000
EMAIL_IMAP_MAX_MESSAGES=10
EMAIL_IMAP_MAX_BYTES=200000
EMAIL_IMAP_MARK_SEEN=false
EMAIL_SMTP_ENABLED=false
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_TLS_REJECT_UNAUTHORIZED=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
EMAIL_PUBLISHER_POLL_MS=2000
